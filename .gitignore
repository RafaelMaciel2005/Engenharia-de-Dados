# ==========================================
# 1. ARQUIVOS TEMPORÁRIOS E DADOS (KAGGLE / OLIST)
# ==========================================
# Ignora a pasta temporária de downloads em qualquer nível do projeto
**/kaggle_data/
/tmp/

# Ignora bases de dados brutas ou extraídas (arquivos pesados)
*.csv
*.zip
*.json
*.parquet
*.avro
*.orc

# ==========================================
# 2. SEGURANÇA E CREDENCIAIS (NUNCA SUBIR)
# ==========================================
# Ignora arquivos de ambiente em qualquer subpasta (Docker, Airflow, etc.)
**/.env
**/*.env
**/*.env.local

# Chaves de API, tokens e arquivos de configuração sensíveis
**/kaggle.json
**/*.pem
**/*.key
**/*.pub

# ==========================================
# 3. DOCKER E VOLUMES LOCAIS
# ==========================================
# Ignora os dados persistidos localmente pelo MinIO, Postgres ou Airflow nos volumes do Docker
**/volumes/
.docker/
**/.minio.sys/

# Lakehouse (bind mount local do MinIO): ignora todo o conteúdo real dos dados
# (parquet, _SUCCESS, metadados internos xl.meta, etc.), mantendo apenas os
# .gitkeep que preservam a estrutura de pastas versionada no repositório
lakehouse/**
!lakehouse/landing-zone/
!lakehouse/landing-zone/.gitkeep
!lakehouse/bronze/
!lakehouse/bronze/.gitkeep
!lakehouse/silver/
!lakehouse/silver/.gitkeep
!lakehouse/gold/
!lakehouse/gold/.gitkeep

# Ignora logs gerados pelos containers
**/logs/
**/*.log

# ==========================================
# 4. PYTHON (AIRFLOW & SPARK)
# ==========================================
# Arquivos compilados do Python (as pastas __pycache__ que vimos no seu print)
**/__pycache__/
*.pyc
*.pyo
*.pyd

# Ambientes virtuais locais
.venv/
venv/
ENV/
env/

# Arquivos de distribuição e build do Python
*.egg-info/
.eggs/
dist/
build/

# ==========================================
# 5. JUPYTER NOTEBOOKS
# ==========================================
# Ignora checkpoints automáticos do Jupyter
**/.ipynb_checkpoints/

# ==========================================
# 6. SISTEMA OPERACIONAL (WINDOWS / MAC)
# ==========================================
Thumbs.db
Desktop.ini
.DS_Store

# Ignorar credenciais e variáveis de ambiente
kaggle.json
.env

